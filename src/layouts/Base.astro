---
export interface Props {
  title?: string;
  description?: string;
}
const {
  title = 'Ryer Guitars — Handcrafted Acoustic Instruments',
  description = 'Custom handcrafted acoustic and classical guitars by luthier Dave Ryer. Built with uncompromising standards in Madoc, Ontario.',
} = Astro.props;
---
<!DOCTYPE html>
<html lang="en">
<head>
  <meta charset="UTF-8">
  <meta name="viewport" content="width=device-width, initial-scale=1.0">
  <title>{title}</title>
  <meta name="description" content={description}>
  <link rel="preconnect" href="https://fonts.googleapis.com">
  <link rel="preconnect" href="https://fonts.gstatic.com" crossorigin>
  <link href="https://fonts.googleapis.com/css2?family=Cormorant+Garamond:ital,wght@0,300;0,400;0,600;1,300;1,400&family=Libre+Franklin:wght@300;400;500&display=swap" rel="stylesheet">
</head>
<body>
  <slot />
</body>
</html>
