---
export interface Props {
  title?: string;
  description?: string;
}
const {
  title = "Ryer Guitars — Handcrafted Acoustic Instruments",
  description = "Custom handcrafted classical and acoustic guitars by luthier David Ryer in Madoc, Ontario. Each instrument is individually designed and built with the finest tone woods.",
} = Astro.props;

const canonicalUrl = new URL(Astro.url.pathname, Astro.site);
const ogImage = new URL('/images/ryer-lg/ryer-lg-100.jpg', Astro.site);
---

<!doctype html>
<html lang='en'>
  <head>
    <meta charset='UTF-8' />
    <meta name='viewport' content='width=device-width, initial-scale=1.0' />
    <title>{title}</title>
    <meta name='description' content={description} />
    <link rel='canonical' href={canonicalUrl.href} />
    <link rel='icon' type='image/svg+xml' href='/favicon.svg' />

    <!-- Open Graph -->
    <meta property='og:type' content='website' />
    <meta property='og:title' content={title} />
    <meta property='og:description' content={description} />
    <meta property='og:url' content={canonicalUrl.href} />
    <meta property='og:image' content={ogImage.href} />
    <meta property='og:image:width' content='1600' />
    <meta property='og:image:height' content='2400' />
    <meta property='og:locale' content='en_CA' />
    <meta property='og:site_name' content='Ryer Guitars' />

    <!-- Twitter -->
    <meta name='twitter:card' content='summary_large_image' />
    <meta name='twitter:title' content={title} />
    <meta name='twitter:description' content={description} />
    <meta name='twitter:image' content={ogImage.href} />

    <!-- Structured Data (LocalBusiness) -->
    <script type='application/ld+json' set:html={JSON.stringify({
      "@context": "https://schema.org",
      "@type": "LocalBusiness",
      "name": "Ryer Guitars",
      "description": description,
      "url": Astro.site?.href,
      "image": ogImage.href,
      "telephone": "+16139695960",
      "email": "dave@ryerguitars.com",
      "address": {
        "@type": "PostalAddress",
        "addressLocality": "Madoc",
        "addressRegion": "ON",
        "addressCountry": "CA"
      },
      "sameAs": [
        "https://www.facebook.com/DnARyerGuitars/",
        "https://www.instagram.com/dnaryerguitars/"
      ],
      "priceRange": "$$$$",
      "knowsAbout": [
        "Classical guitars",
        "Acoustic guitars",
        "Luthier",
        "Custom guitar building",
        "Handcrafted instruments"
      ]
    })} />

    <link rel='preconnect' href='https://fonts.googleapis.com' />
    <link rel='preconnect' href='https://fonts.gstatic.com' crossorigin />
    <link
      href='https://fonts.googleapis.com/css2?family=Cormorant+Garamond:ital,wght@0,300;0,400;0,600;1,300;1,400&family=Libre+Franklin:wght@300;400;500&display=swap'
      rel='stylesheet'
    />
  </head>
  <body>
    <slot />
  </body>
</html>
