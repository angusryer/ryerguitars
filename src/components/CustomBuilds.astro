---

---

<section class='custom' id='custom'>
  <div class='container fade-in'>
    <div class='section-label'>Custom Builds</div>
    <p class='custom-intro'>
      Each instrument is designed and built according to the desires of the player. A 20%
      non-refundable deposit is required to confirm orders.
    </p>
    <div class='price-block'>
      $8,700 standard price <span class='price-note'>+ tax</span>
    </div>
  </div>
</section>

<style>
  .custom {
    background: var(--bg-warm);
  }
  .custom-intro {
    color: var(--cream-dim);
    font-size: 0.95rem;
  }
  .price-block {
    font-family: var(--serif);
    font-size: clamp(1.3rem, 3vw, 1.8rem);
    color: var(--accent);
    margin: 1.5rem 0 2rem;
    font-weight: 300;
  }
  .price-note {
    font-size: 0.9rem;
    color: var(--cream-dim);
  }
  .spec-group {
    margin-top: 2rem;
    max-width: 480px;
  }
  .spec-group h3 {
    font-family: var(--serif);
    font-size: 1rem;
    font-weight: 400;
    color: var(--accent);
    letter-spacing: 0.1em;
    text-transform: uppercase;
    margin-bottom: 0.8rem;
  }
  .spec-group ul {
    list-style: none;
  }
  .spec-group li {
    color: var(--cream-dim);
    font-size: 0.88rem;
    padding: 0.3rem 0;
    border-bottom: 1px solid rgba(201, 169, 110, 0.06);
  }
</style>
