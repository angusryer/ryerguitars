---
<section class="models" id="models">
  <div class="container fade-in">
    <div class="section-label">Gallery</div>
    <div class="gallery-grid">
      {images.map((img, i) => (
        <button class="gallery-card" data-index={i} type="button" aria-label="View full size">
          <img
            src={`/images/${img.src}.jpg`}
            alt={img.alt}
            width="1600"
            height="2400"
            loading="lazy"
            decoding="async"
          >
        </button>
      ))}
    </div>
  </div>
</section>

<!-- Lightbox -->
<div class="lightbox" id="lightbox" aria-hidden="true">
  <button class="lb-close" aria-label="Close">&times;</button>
  <button class="lb-prev" aria-label="Previous">&lsaquo;</button>
  <button class="lb-next" aria-label="Next">&rsaquo;</button>
  <img class="lb-img" id="lb-img" alt="Ryer Guitar full size" />
</div>

<script>
  const sources = Array.from(
    document.querySelectorAll<HTMLImageElement>('.gallery-card img')
  ).map((img) => img.src);

  const lightbox = document.getElementById('lightbox')!;
  const lbImg    = document.getElementById('lb-img') as HTMLImageElement;
  let current    = 0;

  function open(index: number) {
    current = index;
    lbImg.src = sources[current];
    lightbox.classList.add('open');
    lightbox.setAttribute('aria-hidden', 'false');
    document.body.style.overflow = 'hidden';
  }

  function close() {
    lightbox.classList.remove('open');
    lightbox.setAttribute('aria-hidden', 'true');
    document.body.style.overflow = '';
  }

  function prev() {
    current = (current - 1 + sources.length) % sources.length;
    lbImg.src = sources[current];
  }

  function next() {
    current = (current + 1) % sources.length;
    lbImg.src = sources[current];
  }

  // Open on card click
  document.querySelectorAll<HTMLButtonElement>('.gallery-card').forEach((card) => {
    card.addEventListener('click', () => open(Number(card.dataset.index)));
  });

  // Controls
  lightbox.querySelector('.lb-close')!.addEventListener('click', close);
  lightbox.querySelector('.lb-prev')!.addEventListener('click', prev);
  lightbox.querySelector('.lb-next')!.addEventListener('click', next);

  // Click backdrop to close
  lightbox.addEventListener('click', (e) => {
    if (e.target === lightbox) close();
  });

  // Keyboard
  document.addEventListener('keydown', (e) => {
    if (!lightbox.classList.contains('open')) return;
    if (e.key === 'Escape') close();
    if (e.key === 'ArrowLeft') prev();
    if (e.key === 'ArrowRight') next();
  });
</script>

<style>
.gallery-grid {
  display: grid;
  grid-template-columns: repeat(auto-fill, minmax(200px, 1fr));
  gap: 0.75rem; margin-top: 2rem;
}
.gallery-card {
  overflow: hidden; aspect-ratio: 3/4;
  background: var(--bg-card);
  border: 1px solid rgba(201, 169, 110, 0.08);
  transition: border-color 0.4s;
  padding: 0; cursor: pointer;
  display: block; width: 100%;
}
.gallery-card:hover { border-color: rgba(201, 169, 110, 0.3); }
.gallery-card img {
  width: 100%; height: 100%; object-fit: cover;
  display: block; transition: transform 0.6s ease;
  background: var(--bg-card);
  pointer-events: none;
}
.gallery-card:hover img { transform: scale(1.04); }
@media (max-width: 540px) {
  .gallery-grid { grid-template-columns: repeat(2, 1fr); gap: 0.5rem; }
}

/* ── Lightbox ── */
.lightbox {
  position: fixed; inset: 0; z-index: 200;
  display: flex; align-items: center; justify-content: center;
  background: rgba(10, 8, 6, 0.92);
  backdrop-filter: blur(8px);
  -webkit-backdrop-filter: blur(8px);
  opacity: 0; visibility: hidden;
  transition: opacity 0.3s, visibility 0.3s;
}
.lightbox.open {
  opacity: 1; visibility: visible;
}
.lb-img {
  max-width: 90vw; max-height: 90vh;
  object-fit: contain;
  display: block;
  transition: opacity 0.2s;
}
.lb-close, .lb-prev, .lb-next {
  position: fixed;
  background: none; border: none;
  color: var(--cream-dim);
  cursor: pointer;
  transition: color 0.2s;
  font-family: var(--sans);
  z-index: 201;
}
.lb-close:hover, .lb-prev:hover, .lb-next:hover {
  color: var(--cream);
}
.lb-close {
  top: 1.2rem; right: 1.5rem;
  font-size: 2.2rem; line-height: 1;
}
.lb-prev, .lb-next {
  top: 50%; transform: translateY(-50%);
  font-size: 3rem; line-height: 1;
  padding: 0.5rem;
}
.lb-prev { left: 1rem; }
.lb-next { right: 1rem; }

@media (max-width: 540px) {
  .lb-prev, .lb-next { font-size: 2rem; }
  .lb-prev { left: 0.5rem; }
  .lb-next { right: 0.5rem; }
}
</style>
