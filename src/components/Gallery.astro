---
const images = [
  'ryer-lg-100', 'ryer-lg-104', 'ryer-lg-108', 'ryer-lg-112',
  'ryer-lg-116', 'ryer-lg-120', 'ryer-lg-124', 'ryer-lg-128',
  'ryer-lg-132', 'ryer-lg-136', 'ryer-lg-140', 'ryer-lg-144',
];
---
<section class="models" id="models">
  <div class="container fade-in">
    <div class="section-label">Gallery</div>
    <div class="gallery-grid">
      {images.map((img) => (
        <div class="gallery-card">
          <img
            src={`/images/ryer-lg/${img}.jpg`}
            alt="Ryer Guitar"
            width="1600"
            height="2400"
            loading="lazy"
            decoding="async"
          >
        </div>
      ))}
    </div>
  </div>
</section>

<style>
.gallery-grid {
  display: grid;
  grid-template-columns: repeat(auto-fill, minmax(200px, 1fr));
  gap: 0.75rem; margin-top: 2rem;
}
.gallery-card {
  overflow: hidden; aspect-ratio: 3/4;
  background: var(--bg-card);
  border: 1px solid rgba(201, 169, 110, 0.08);
  transition: border-color 0.4s;
}
.gallery-card:hover { border-color: rgba(201, 169, 110, 0.3); }
.gallery-card img {
  width: 100%; height: 100%; object-fit: cover;
  display: block; transition: transform 0.6s ease;
  background: var(--bg-card);
}
.gallery-card:hover img { transform: scale(1.04); }
@media (max-width: 540px) {
  .gallery-grid { grid-template-columns: repeat(2, 1fr); gap: 0.5rem; }
}
</style>
