---

---

<section class='contact' id='contact'>
  <div class='container fade-in'>
    <div class='section-label'>Contact</div>
    <p class='contact-intro'>
      Have a question about a build, want to discuss a commission, or just want to talk guitars?
      Send me a message below.
    </p>

    <form id='contact-form' novalidate>
      <div class='form-row'>
        <div class='form-field'>
          <label for='cf-name'>Name</label>
          <input id='cf-name' name='from_name' type='text' placeholder='Your name' required />
        </div>
        <div class='form-field'>
          <label for='cf-email'>Email</label>
          <input
            id='cf-email'
            name='from_email'
            type='email'
            placeholder='your@email.com'
            required
          />
        </div>
      </div>
      <div class='form-field'>
        <label for='cf-message'>Message</label>
        <textarea
          id='cf-message'
          name='message'
          rows='6'
          placeholder="What's on your mind…"
          required></textarea>
      </div>
      <button type='submit' class='form-submit'>
        <span class='submit-label'>Send Message</span>
        <span class='submit-sending' aria-hidden='true'>Sending…</span>
      </button>
      <p class='form-status' aria-live='polite'></p>
    </form>

    <div class='contact-alt'>
      <div class='contact-phone'>613 969 5960</div>
      <div class='contact-line'>
        <a href='mailto:dave@ryerguitars.com'>dave@ryerguitars.com</a>
      </div>
      <div class='social-links'>
        <a href='https://www.facebook.com/DnARyerGuitars/' target='_blank' rel='noopener' aria-label='Facebook'>
          <svg xmlns='http://www.w3.org/2000/svg' viewBox='0 0 24 24' fill='currentColor' aria-hidden='true'>
            <path d='M22 12c0-5.523-4.477-10-10-10S2 6.477 2 12c0 4.991 3.657 9.128 8.438 9.878v-6.987h-2.54V12h2.54V9.797c0-2.506 1.492-3.89 3.777-3.89 1.094 0 2.238.195 2.238.195v2.46h-1.26c-1.243 0-1.63.771-1.63 1.562V12h2.773l-.443 2.89h-2.33v6.988C18.343 21.128 22 16.991 22 12z'/>
          </svg>
        </a>
        <a href='https://www.instagram.com/dnaryerguitars/' target='_blank' rel='noopener' aria-label='Instagram'>
          <svg xmlns='http://www.w3.org/2000/svg' viewBox='0 0 24 24' fill='currentColor' aria-hidden='true'>
            <path d='M12 2.163c3.204 0 3.584.012 4.85.07 3.252.148 4.771 1.691 4.919 4.919.058 1.265.069 1.645.069 4.849 0 3.205-.012 3.584-.069 4.849-.149 3.225-1.664 4.771-4.919 4.919-1.266.058-1.644.07-4.85.07-3.204 0-3.584-.012-4.849-.07-3.26-.149-4.771-1.699-4.919-4.92-.058-1.265-.07-1.644-.07-4.849 0-3.204.013-3.583.07-4.849.149-3.227 1.664-4.771 4.919-4.919 1.266-.057 1.645-.069 4.849-.069zM12 0C8.741 0 8.333.014 7.053.072 2.695.272.273 2.69.073 7.052.014 8.333 0 8.741 0 12c0 3.259.014 3.668.072 4.948.2 4.358 2.618 6.78 6.98 6.98C8.333 23.986 8.741 24 12 24c3.259 0 3.668-.014 4.948-.072 4.354-.2 6.782-2.618 6.979-6.98.059-1.28.073-1.689.073-4.948 0-3.259-.014-3.667-.072-4.947-.196-4.354-2.617-6.78-6.979-6.98C15.668.014 15.259 0 12 0zm0 5.838a6.162 6.162 0 100 12.324 6.162 6.162 0 000-12.324zM12 16a4 4 0 110-8 4 4 0 010 8zm6.406-11.845a1.44 1.44 0 100 2.881 1.44 1.44 0 000-2.881z'/>
          </svg>
        </a>
      </div>
    </div>
  </div>
</section>

<script>
  import emailjs from "@emailjs/browser";

  const PUBLIC_KEY  = "W_sUo8TZ8Z52JAwbc";
  const SERVICE_ID  = "service_ihwipst";
  const TEMPLATE_ID = "template_z00etfu";

  emailjs.init({ publicKey: PUBLIC_KEY });

  const form   = document.getElementById("contact-form") as HTMLFormElement;
  const status = form.querySelector(".form-status") as HTMLElement;
  const btn    = form.querySelector(".form-submit") as HTMLButtonElement;

  form.addEventListener("submit", async (e) => {
    e.preventDefault();
    if (!form.checkValidity()) { form.reportValidity(); return; }

    btn.classList.add("sending");
    btn.disabled = true;
    status.textContent = "";

    try {
      const senderName  = (form.querySelector('[name="from_name"]') as HTMLInputElement).value;
      const senderEmail = (form.querySelector('[name="from_email"]') as HTMLInputElement).value;

      await emailjs.send(SERVICE_ID, TEMPLATE_ID, {
        name:    senderName,
        email:   senderEmail,   // matches {{email}} in Reply To
        title:   `Message from ${senderName}`,  // matches {{title}} in Subject
        message: (form.querySelector('[name="message"]') as HTMLTextAreaElement).value,
      });
      status.textContent = "Message sent — Dave will be in touch soon.";
      status.className = "form-status success";
      form.reset();
    } catch (err) {
      console.error("EmailJS error:", err);
      status.textContent = "Something went wrong. Please try emailing dave@ryerguitars.com directly.";
      status.className = "form-status error";
    } finally {
      btn.classList.remove("sending");
      btn.disabled = false;
    }
  });
</script>

<style>
  .contact {
    text-align: left;
  }
  .contact-intro {
    color: var(--cream-dim);
    font-size: 0.95rem;
    max-width: 560px;
    margin-bottom: 2.5rem;
  }

  /* ── FORM ── */
  #contact-form {
    max-width: 620px;
  }

  .form-row {
    display: grid;
    grid-template-columns: 1fr 1fr;
    gap: 1rem;
  }
  @media (max-width: 540px) {
    .form-row {
      grid-template-columns: 1fr;
    }
  }

  .form-field {
    display: flex;
    flex-direction: column;
    gap: 0.4rem;
    margin-bottom: 1.2rem;
  }
  .form-field label {
    font-size: 0.72rem;
    letter-spacing: 0.12em;
    text-transform: uppercase;
    color: var(--cream-dim);
  }
  .form-field input,
  .form-field textarea {
    background: var(--bg-card);
    border: 1px solid rgba(201, 169, 110, 0.15);
    color: var(--cream);
    font-family: var(--sans);
    font-size: 0.92rem;
    font-weight: 300;
    padding: 0.7rem 0.9rem;
    outline: none;
    transition: border-color 0.25s;
    resize: vertical;
  }
  .form-field input::placeholder,
  .form-field textarea::placeholder {
    color: var(--cream-dim);
    opacity: 0.5;
  }
  .form-field input:focus,
  .form-field textarea:focus {
    border-color: rgba(201, 169, 110, 0.5);
  }

  .form-submit {
    display: inline-block;
    position: relative;
    background: transparent;
    border: 1px solid rgba(201, 169, 110, 0.4);
    color: var(--accent);
    font-family: var(--sans);
    font-size: 0.78rem;
    letter-spacing: 0.15em;
    text-transform: uppercase;
    padding: 0.75rem 2rem;
    cursor: pointer;
    transition:
      border-color 0.3s,
      color 0.3s;
    margin-top: 0.5rem;
  }
  .form-submit:hover {
    border-color: var(--accent);
    color: var(--cream);
  }
  .form-submit:disabled {
    opacity: 0.5;
    cursor: default;
  }

  /* swap label/sending text */
  .submit-sending {
    display: none;
  }
  .form-submit.sending .submit-label {
    display: none;
  }
  .form-submit.sending .submit-sending {
    display: inline;
  }

  .form-status {
    margin-top: 1rem;
    font-size: 0.88rem;
    min-height: 1.4em;
  }
  .form-status.success {
    color: var(--accent);
  }
  .form-status.error {
    color: #c97070;
  }

  /* ── ALT CONTACT ── */
  .contact-alt {
    margin-top: 3.5rem;
    padding-top: 2rem;
    border-top: 1px solid rgba(201, 169, 110, 0.08);
  }
  .contact-phone {
    font-family: var(--serif);
    font-size: clamp(1.2rem, 3vw, 1.6rem);
    color: var(--cream);
    letter-spacing: 0.05em;
    margin-bottom: 0.6rem;
  }
  .contact-line {
    margin: 0.6rem 0;
    font-size: 1rem;
    color: var(--cream-dim);
  }
  .contact-line a {
    color: var(--cream);
    text-decoration: none;
    border-bottom: 1px solid rgba(201, 169, 110, 0.3);
    transition: border-color 0.3s;
  }
  .contact-line a:hover {
    border-color: var(--accent);
  }
  .social-links {
    margin-top: 1.5rem;
    display: flex;
    gap: 1rem;
  }
  .social-links a {
    display: inline-flex;
    align-items: center;
    justify-content: center;
    color: var(--accent-dim);
    text-decoration: none;
    padding: 0.5rem;
    border: 1px solid rgba(201, 169, 110, 0.2);
    transition: all 0.3s;
  }
  .social-links a:hover {
    color: var(--accent);
    border-color: var(--accent);
  }
  .social-links svg {
    width: 1.3rem;
    height: 1.3rem;
    display: block;
  }
</style>
