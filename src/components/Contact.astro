---

---

<section class='contact' id='contact'>
  <div class='container fade-in'>
    <div class='section-label'>Contact Dave</div>
    <p class='contact-intro'>
      Have a question about a build, want to discuss a commission, or just want to talk guitars?
      Send a message below.
    </p>

    <form id='contact-form' novalidate>
      <div class='form-row'>
        <div class='form-field'>
          <label for='cf-name'>Name</label>
          <input id='cf-name' name='from_name' type='text' placeholder='Your name' required />
        </div>
        <div class='form-field'>
          <label for='cf-email'>Email</label>
          <input
            id='cf-email'
            name='from_email'
            type='email'
            placeholder='your@email.com'
            required
          />
        </div>
      </div>
      <div class='form-field'>
        <label for='cf-message'>Message</label>
        <textarea
          id='cf-message'
          name='message'
          rows='6'
          placeholder="Tell Dave what's on your mind…"
          required></textarea>
      </div>
      <button type='submit' class='form-submit'>
        <span class='submit-label'>Send Message</span>
        <span class='submit-sending' aria-hidden='true'>Sending…</span>
      </button>
      <p class='form-status' aria-live='polite'></p>
    </form>

    <div class='contact-alt'>
      <div class='contact-phone'>613 969 5960</div>
      <div class='contact-line'>
        <a href='mailto:dave@ryerguitars.com'>dave@ryerguitars.com</a>
      </div>
      <div class='social-links'>
        <a href='https://www.facebook.com/DnARyerGuitars/' target='_blank' rel='noopener'
          >Facebook</a
        >
      </div>
    </div>
  </div>
</section>

<script>
  import emailjs from "@emailjs/browser";

  const PUBLIC_KEY  = "W_sUo8TZ8Z52JAwbc";
  const SERVICE_ID  = "service_ihwipst";
  const TEMPLATE_ID = "template_z00etfu";

  emailjs.init({ publicKey: PUBLIC_KEY });

  const form   = document.getElementById("contact-form") as HTMLFormElement;
  const status = form.querySelector(".form-status") as HTMLElement;
  const btn    = form.querySelector(".form-submit") as HTMLButtonElement;

  form.addEventListener("submit", async (e) => {
    e.preventDefault();
    if (!form.checkValidity()) { form.reportValidity(); return; }

    btn.classList.add("sending");
    btn.disabled = true;
    status.textContent = "";

    try {
      const senderName  = (form.querySelector('[name="from_name"]') as HTMLInputElement).value;
      const senderEmail = (form.querySelector('[name="from_email"]') as HTMLInputElement).value;

      await emailjs.send(SERVICE_ID, TEMPLATE_ID, {
        name:    senderName,
        email:   senderEmail,   // matches {{email}} in Reply To
        title:   `Message from ${senderName}`,  // matches {{title}} in Subject
        message: (form.querySelector('[name="message"]') as HTMLTextAreaElement).value,
      });
      status.textContent = "Message sent — Dave will be in touch soon.";
      status.className = "form-status success";
      form.reset();
    } catch (err) {
      console.error("EmailJS error:", err);
      status.textContent = "Something went wrong. Please try emailing dave@ryerguitars.com directly.";
      status.className = "form-status error";
    } finally {
      btn.classList.remove("sending");
      btn.disabled = false;
    }
  });
</script>

<style>
  .contact {
    text-align: left;
  }
  .contact-intro {
    color: var(--cream-dim);
    font-size: 0.95rem;
    max-width: 560px;
    margin-bottom: 2.5rem;
  }

  /* ── FORM ── */
  #contact-form {
    max-width: 620px;
  }

  .form-row {
    display: grid;
    grid-template-columns: 1fr 1fr;
    gap: 1rem;
  }
  @media (max-width: 540px) {
    .form-row {
      grid-template-columns: 1fr;
    }
  }

  .form-field {
    display: flex;
    flex-direction: column;
    gap: 0.4rem;
    margin-bottom: 1.2rem;
  }
  .form-field label {
    font-size: 0.72rem;
    letter-spacing: 0.12em;
    text-transform: uppercase;
    color: var(--cream-dim);
  }
  .form-field input,
  .form-field textarea {
    background: var(--bg-card);
    border: 1px solid rgba(201, 169, 110, 0.15);
    color: var(--cream);
    font-family: var(--sans);
    font-size: 0.92rem;
    font-weight: 300;
    padding: 0.7rem 0.9rem;
    outline: none;
    transition: border-color 0.25s;
    resize: vertical;
  }
  .form-field input::placeholder,
  .form-field textarea::placeholder {
    color: var(--cream-dim);
    opacity: 0.5;
  }
  .form-field input:focus,
  .form-field textarea:focus {
    border-color: rgba(201, 169, 110, 0.5);
  }

  .form-submit {
    display: inline-block;
    position: relative;
    background: transparent;
    border: 1px solid rgba(201, 169, 110, 0.4);
    color: var(--accent);
    font-family: var(--sans);
    font-size: 0.78rem;
    letter-spacing: 0.15em;
    text-transform: uppercase;
    padding: 0.75rem 2rem;
    cursor: pointer;
    transition:
      border-color 0.3s,
      color 0.3s;
    margin-top: 0.5rem;
  }
  .form-submit:hover {
    border-color: var(--accent);
    color: var(--cream);
  }
  .form-submit:disabled {
    opacity: 0.5;
    cursor: default;
  }

  /* swap label/sending text */
  .submit-sending {
    display: none;
  }
  .form-submit.sending .submit-label {
    display: none;
  }
  .form-submit.sending .submit-sending {
    display: inline;
  }

  .form-status {
    margin-top: 1rem;
    font-size: 0.88rem;
    min-height: 1.4em;
  }
  .form-status.success {
    color: var(--accent);
  }
  .form-status.error {
    color: #c97070;
  }

  /* ── ALT CONTACT ── */
  .contact-alt {
    margin-top: 3.5rem;
    padding-top: 2rem;
    border-top: 1px solid rgba(201, 169, 110, 0.08);
  }
  .contact-phone {
    font-family: var(--serif);
    font-size: clamp(1.2rem, 3vw, 1.6rem);
    color: var(--cream);
    letter-spacing: 0.05em;
    margin-bottom: 0.6rem;
  }
  .contact-line {
    margin: 0.6rem 0;
    font-size: 1rem;
    color: var(--cream-dim);
  }
  .contact-line a {
    color: var(--cream);
    text-decoration: none;
    border-bottom: 1px solid rgba(201, 169, 110, 0.3);
    transition: border-color 0.3s;
  }
  .contact-line a:hover {
    border-color: var(--accent);
  }
  .social-links {
    margin-top: 1.5rem;
  }
  .social-links a {
    display: inline-block;
    color: var(--accent-dim);
    font-size: 0.78rem;
    letter-spacing: 0.15em;
    text-transform: uppercase;
    text-decoration: none;
    padding: 0.6rem 1.2rem;
    border: 1px solid rgba(201, 169, 110, 0.2);
    transition: all 0.3s;
  }
  .social-links a:hover {
    color: var(--accent);
    border-color: var(--accent);
  }
</style>
